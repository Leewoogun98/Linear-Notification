{
  "name": "linear-noti-app",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "node -e \"const fs=require('fs');const p='src/renderer/notification';fs.mkdirSync('dist/renderer/notification',{recursive:true});for(const f of ['index.html','notification.css'])fs.copyFileSync(p+'/'+f,'dist/renderer/notification/'+f);\"",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/ws": "^8.5.10"
  },
  "dependencies": {
    "ws": "^8.17.0",
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.woogun.linearnoti",
    "files": ["dist/**/*"],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" }
  }
}
